{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "bat13adf"
		},
		"ADLS_LINKED_SERVICE_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_LINKED_SERVICE'"
		},
		"Blob_Linked_Service_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Blob_Linked_Service'"
		},
		"SQLDB_LINKED_SERVICE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SQLDB_LINKED_SERVICE'"
		},
		"sql_db_parameterization_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'sql_db_parameterization'"
		},
		"ADLS_LINKED_SERVICE_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://bat12adls.dfs.core.windows.net/"
		},
		"SQLDB_LINKED_SERVICE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mission100server.database.windows.net"
		},
		"SQLDB_LINKED_SERVICE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "batch12db"
		},
		"SQLDB_LINKED_SERVICE_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure"
		},
		"sql_db_parameterization_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mission100server.database.windows.net"
		},
		"sql_db_parameterization_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "batch12db"
		},
		"sql_db_parameterization_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "@{linkedService().userName}"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "bat13adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_LINKED_SERVICE_accountKey": {
						"value": "[parameters('ADLS_LINKED_SERVICE_accountKey')]"
					},
					"Blob_Linked_Service_connectionString": {
						"value": "[parameters('Blob_Linked_Service_connectionString')]"
					},
					"SQLDB_LINKED_SERVICE_password": {
						"value": "[parameters('SQLDB_LINKED_SERVICE_password')]"
					},
					"sql_db_parameterization_password": {
						"value": "[parameters('sql_db_parameterization_password')]"
					},
					"ADLS_LINKED_SERVICE_properties_typeProperties_url": {
						"value": "[parameters('ADLS_LINKED_SERVICE_properties_typeProperties_url')]"
					},
					"SQLDB_LINKED_SERVICE_properties_typeProperties_server": {
						"value": "[parameters('SQLDB_LINKED_SERVICE_properties_typeProperties_server')]"
					},
					"SQLDB_LINKED_SERVICE_properties_typeProperties_database": {
						"value": "[parameters('SQLDB_LINKED_SERVICE_properties_typeProperties_database')]"
					},
					"SQLDB_LINKED_SERVICE_properties_typeProperties_userName": {
						"value": "[parameters('SQLDB_LINKED_SERVICE_properties_typeProperties_userName')]"
					},
					"sql_db_parameterization_properties_typeProperties_server": {
						"value": "[parameters('sql_db_parameterization_properties_typeProperties_server')]"
					},
					"sql_db_parameterization_properties_typeProperties_database": {
						"value": "[parameters('sql_db_parameterization_properties_typeProperties_database')]"
					},
					"sql_db_parameterization_properties_typeProperties_userName": {
						"value": "[parameters('sql_db_parameterization_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "bat13adf_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'bat13adf_ArmTemplate_0')]"
			]
		}
	]
}